# Autheo v3 Configuration
# Copy this file to .env and adjust values as needed

# Database backend: sqlite, postgres, mysql, mariadb, duckdb
AUTHEO_DB_BACKEND=sqlite

# Database connection (for postgres/mysql/mariadb)
AUTHEO_DB_HOST=localhost
AUTHEO_DB_PORT=
AUTHEO_DB_NAME=autheo
AUTHEO_DB_USER=
AUTHEO_DB_PASSWORD=

# Database file path (for sqlite/duckdb)
AUTHEO_DB_PATH=dbs/autheo.db

# JWT token expiry in days
AUTHEO_JWT_EXPIRY_DAYS=7

# Server settings
AUTHEO_PORT=8800
AUTHEO_HOST=0.0.0.0
AUTHEO_DEBUG=true
